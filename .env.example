# 这个文件用于展示本地开发和部署所需环境变量，不包含真实密钥。

APP_ENV=development
APP_SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:3000

POSTGRES_DB=patent_check_agent
POSTGRES_USER=patent_user
POSTGRES_PASSWORD=patent_password
DATABASE_URL=postgresql+psycopg://patent_user:patent_password@postgres:5432/patent_check_agent

REDIS_URL=redis://redis:6379/0

GPT_BASE_URL=https://helloapi.cc
GPT_API_KEY=replace-with-your-api-key
GPT_MODEL=gpt-5.5
GPT_TIMEOUT_SECONDS=180
GPT_MAX_RETRIES=2

MAX_FILE_SIZE_MB=20
MAX_TASK_FILES=4
MAX_TOTAL_TEXT_CHARS=200000
UPLOAD_DIR=/app/uploads

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMeAdmin123!
SEED_USER1_USERNAME=researcher1
SEED_USER1_PASSWORD=ChangeMeUser123!
SEED_USER2_USERNAME=researcher2
SEED_USER2_PASSWORD=ChangeMeUser123!
